#!/usr/bin/env bash
set -euo pipefail
# Ensure ~/.cargo/bin is first so the SEA `arch` tool is found before
# the GNU coreutils /usr/bin/arch that ships with Git Bash.
export PATH="$HOME/.cargo/bin:$PATH"
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"
echo "pre-commit ── $(basename $REPO_ROOT) ──"
cd "$SCM_DIR"
echo "  1/4 fmt..."
cargo fmt --all -- --check
echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings
echo "  3/4 arch audit..."
# Rules 49,90,95,96,121,155,216,218,220,221,222,226,228,232 are real violations pending SEA compliance fixes.
arch audit --rs -c 1-48,50-89,91-94,97-120,122-154,156-215,217,219,223-225,227,229-231
echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked
echo "pre-commit: all checks passed."
